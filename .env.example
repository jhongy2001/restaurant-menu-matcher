APP_NAME=Restaurant Menu Photo Matcher
APP_ENV=dev
APP_HOST=127.0.0.1
APP_PORT=8000
APP_DEBUG=true

# External providers (fill when available)
# Data provider mode: demo keeps mock fallback, real requires configured APIs
DATA_PROVIDER_MODE=demo
YELP_API_KEY=
# Used for Autocomplete (legacy) and Places API (New): Text Search, Details, Photos, businessMenus
GOOGLE_PLACES_API_KEY=
SERPAPI_API_KEY=

# Image source backend: review_match | serpapi_search
IMAGE_SOURCE_BACKEND=serpapi_search

# Image matcher backend: lexical | clip | hybrid
IMAGE_MATCHER_BACKEND=hybrid
CLIP_MODEL_NAME=openai/clip-vit-base-patch32
CLIP_REQUEST_TIMEOUT_SECONDS=8
CLIP_MAX_IMAGES_PER_REQUEST=8
SERPAPI_TIMEOUT_SECONDS=8
SERPAPI_MAX_RESULTS=5

# Search and ranking behavior
DEFAULT_TOP_K=5
MAX_TOP_K=10
CACHE_TTL_SECONDS=900
